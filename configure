function PARTITIONING_DEVICES_tag()   { echo " └ 設備"; }
function PARTITIONING_DEVICES_label() {
	local invalid=0
	for dev in "${PARTITIONING_DEVICES[@]}"; do
		[[ -e "$dev" ]] \
			|| ((++invalid))
	done

	if [[ "$invalid" -gt 0 ]]; then
		echo " └ (${#PARTITIONING_DEVICES[@]} 個設備, \Z1$invalid 無效\Zn)"
	elif [[ "${#PARTITIONING_DEVICES[@]}" -eq 1 && ("$PARTITIONING_SCHEME" == "raid0_luks" || "$PARTITIONING_SCHEME" == "raid1_luks") ]]; then
		echo " └ (${#PARTITIONING_DEVICES[@]} 個設備, \Z1需要至少2個\Zn)"
	elif [[ "${#PARTITIONING_DEVICES[@]}" -eq 0 ]]; then
		echo " └ (${#PARTITIONING_DEVICES[@]} 個設備, \Z1需要至少1個\Zn)"
	else
		echo " └ (${#PARTITIONING_DEVICES[@]} 個設備)"
	fi
}
function PARTITIONING_DEVICES_show()  { [[ $PARTITIONING_SCHEME != "custom" ]] && one_of "$PARTITIONING_SCHEME" "raid0_luks" "raid1_luks" "zfs_centric" "btrfs_centric"; }
function PARTITIONING_DEVICES_help()  { echo "將應用該佈局之塊設備。"; }
function PARTITIONING_DEVICES_menu()  {
	local invalid=()
	for dev in "${PARTITIONING_DEVICES[@]}"; do
		[[ -e "$dev" ]] \
			|| invalid+=("$dev")
	done

	local invalid_line=""
	if [[ "${#invalid[@]}" -gt 0 ]]; then
		invalid_line="\n\n無效設備: \Z1${invalid[*]}\Zn"
	fi

	dialog \
		--title "選擇設備" \
		--inputbox "輸入所需分區之全部設備，以空格分開。（例如 /dev/sda /dev/sdb ）$invalid_line" \
		"${INPUTBOX_SIZE[@]}" "${PARTITIONING_DEVICES[*]}" \
		|| return 0
	read -ra PARTITIONING_DEVICES <<< "$dialog_out"
	UNSAVED_CHANGES=true
}

