function HOSTNAME_label() { echo "($HOSTNAME)"; }
function HOSTNAME_show()  { return 0; }
function HOSTNAME_help()  { echo "在此輸入主機名。注意創建 mdadm raid 陣列時，該值將被記錄於元數據塊。若在之後發生變更，閣下應同時更新元數據。"; }
function HOSTNAME_menu()  {
	dialog \
		--title "選擇主機名" \
		--inputbox "為新系統輸入主機名" \
		"${INPUTBOX_SIZE[@]}" "$HOSTNAME" \
		|| return 0
	HOSTNAME="$dialog_out"
	UNSAVED_CHANGES=true
}

